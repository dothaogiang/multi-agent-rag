# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith (optional but recommended)
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=travel-rag-assistant

# GCP
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp_key.json
GCS_BUCKET_BRONZE=travel-rag-bronze
GCS_BUCKET_SILVER=travel-rag-silver
BIGQUERY_DATASET=travel_data

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=travel_policies

# Airflow
AIRFLOW_HOME=./airflow